{
  "name": "clore-app",
  "main": "electron/main.js",
  "author": "Clore Team <marketing@clore.ai>",
  "homepage": "https://clore.ai",
  "description": "Clore.ai light wallet supporting multiple wallets, sending, storing, and Proof of Holdings Signatures.",
  "version": "2.0.0-alpha",
  "private": true,
  "engines": {
    "node": ">=20.0"
  },
  "scripts": {
    "compile": "tsc",
    "compile:watch": "tsc -w",
    "build": "next build",
    "dev": "next dev",
    "lint": "eslint \"components/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix \"components/**/*.{ts,tsx}\"",
    "prettier": "prettier --write \"components/**/*.{ts,tsx}\"",
    "serve": "npx serve out",
    "sync": "npx cap sync",
    "copy": "npx cap copy",
    "add:android": "npx cap add android",
    "add:ios": "npx cap add ios",
    "android": "npx cap open android",
    "ios": "npx cap open ios",
    "clean": "rm -r out && rm -r node_modules",
    "electron:dev": "electron .",
    "electron:build": "electron-builder build",
    "electron:build:mac:arm": "electron-builder build --mac --arm64",
    "electron:build:mac:universal": "electron-builder build --mac --universal",
    "electron:build:linux:arm": "electron-builder build --linux --arm64",
    "electron:build:linux:64": "electron-builder build --linux --x64",
    "electron:build:win:32": "electron-builder build --win --ia32",
    "electron:build:win:64": "electron-builder build --win --x64",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "8.0.2",
    "@aparajita/capacitor-secure-storage": "6.0.1",
    "@capacitor-community/electron": "5.0.1",
    "@capacitor/android": "6.1.2",
    "@capacitor/clipboard": "6.0.1",
    "@capacitor/core": "6.1.2",
    "@capacitor/ios": "6.1.2",
    "@capacitor/preferences": "6.0.2",
    "@capacitor/status-bar": "6.0.1",
    "@capacitor/toast": "6.0.2",
    "@hookform/resolvers": "3.3.4",
    "@ionic/react": "7.7.4",
    "@ionic/react-router": "7.7.4",
    "@ionic/storage": "4.0.0",
    "@scure/bip39": "1.3.0",
    "aes-js": "3.1.2",
